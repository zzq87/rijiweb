# 日记网站环境变量配置
# 复制此文件为 .env 并修改密钥值

# 运行环境: development / production
DIARY_ENV=production

# 密钥 - 请修改为随机字符串 (production 环境必须修改)
# 使用 python -c "import secrets; print(secrets.token_hex(32))" 生成
DIARY_SECRET_KEY=change-me-to-random-hex
DIARY_CSRF_KEY=change-me-to-different-random-hex
DIARY_ENC_KEY=change-me-to-another-random-hex

# 数据库路径 (默认 data/riji.db)
DIARY_DB_URI=sqlite:///data/riji.db

# 启用安全 Cookie (production 建议 true, 需 HTTPS)
DIARY_SECURE_COOKIE=true
